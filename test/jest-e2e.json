{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^tronweb$": "<rootDir>/mocks/tronweb.ts",
    "^@stellar/stellar-sdk$": "<rootDir>/mocks/stellar-sdk.ts"
  },
  "testTimeout": 60000
}
