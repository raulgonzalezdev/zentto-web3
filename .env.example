# ─────────────────────────────────────────────────────────────
# Zentto Web3 — variables de entorno (copiar a .env)
# ─────────────────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=4100
API_PREFIX=api
CORS_ORIGIN=*

# Base de datos PROPIA de este servicio (independiente del ERP)
DB_HOST=localhost
DB_PORT=5544
DB_USER=web3
# Define una contraseña local (este archivo es solo un ejemplo; el real es .env, ignorado por git).
DB_PASSWORD=CHANGE_ME_local_dev
DB_NAME=zentto_web3
DB_SYNCHRONIZE=true
DB_LOGGING=false

# Redis (cola asíncrona BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6399

# Blockchain
CHAIN_DIFFICULTY=3
MINING_REWARD=50
GENESIS_PREMINE_ADDRESS=

# Cumplimiento AML
AML_HIGH_RISK_THRESHOLD=70
AML_STRUCTURING_AMOUNT=9000

# IA (informes de cumplimiento). Sin key => generador determinista (100% funcional offline).
# Proveedor: auto | anthropic | openai | deepseek | none
AI_PROVIDER=auto
# Anthropic (Claude)
ANTHROPIC_API_KEY=
# OpenAI o DeepSeek (compatible OpenAI). Para DeepSeek: AI_PROVIDER=deepseek y
# OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# Override de modelo (vacío = default por proveedor: claude-opus-4-8 / gpt-4o-mini / deepseek-chat)
AI_MODEL=
AI_EFFORT=medium

# ─────────────────────────────────────────────────────────────
# Autenticación (JWT en cookies httpOnly + 2FA TOTP)
# OBLIGATORIO: genera secretos reales y fuertes (mín. 32 chars):
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Nunca uses valores de ejemplo en producción.
# ─────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
BCRYPT_ROUNDS=12
TOTP_ISSUER=Zentto Web3
COOKIE_DOMAIN=
# En producción (HTTPS): COOKIE_SECURE=true y COOKIE_SAMESITE=none si front y API en dominios distintos.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
