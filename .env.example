# ─────────────────────────────────────────────────────────────
# Zentto Web3 — variables de entorno (copiar a .env)
# ─────────────────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=4100
API_PREFIX=api
CORS_ORIGIN=*

# Base de datos PROPIA de este servicio (independiente del ERP)
DB_HOST=localhost
DB_PORT=5544
DB_USER=web3
# Define una contraseña local (este archivo es solo un ejemplo; el real es .env, ignorado por git).
DB_PASSWORD=CHANGE_ME_local_dev
DB_NAME=zentto_web3
DB_SYNCHRONIZE=true
DB_LOGGING=false

# Redis (cola asíncrona BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6399

# Blockchain
CHAIN_DIFFICULTY=3
MINING_REWARD=50
GENESIS_PREMINE_ADDRESS=

# Cumplimiento AML
AML_HIGH_RISK_THRESHOLD=70
AML_STRUCTURING_AMOUNT=9000

# IA (informes de cumplimiento). Si se deja vacío, se usa el generador determinista.
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8
AI_EFFORT=medium
