# ─────────────────────────────────────────────────────────────
# Zentto Web3 — variables de entorno (copiar a .env)
# ─────────────────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=4100
API_PREFIX=api
CORS_ORIGIN=*

# Base de datos PROPIA de este servicio (independiente del ERP)
DB_HOST=localhost
DB_PORT=5544
DB_USER=web3
# Define una contraseña local (este archivo es solo un ejemplo; el real es .env, ignorado por git).
DB_PASSWORD=CHANGE_ME_local_dev
DB_NAME=zentto_web3
DB_SYNCHRONIZE=true
DB_LOGGING=false

# Redis (cola asíncrona BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6399

# Blockchain
CHAIN_DIFFICULTY=3
MINING_REWARD=50
GENESIS_PREMINE_ADDRESS=

# Cumplimiento AML
AML_HIGH_RISK_THRESHOLD=70
AML_STRUCTURING_AMOUNT=9000

# IA (informes de cumplimiento). Sin key => generador determinista (100% funcional offline).
# Proveedor: auto | anthropic | openai | deepseek | none
AI_PROVIDER=auto
# Anthropic (Claude)
ANTHROPIC_API_KEY=
# OpenAI o DeepSeek (compatible OpenAI). Para DeepSeek: AI_PROVIDER=deepseek y
# OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# Override de modelo (vacío = default por proveedor: claude-opus-4-8 / gpt-4o-mini / deepseek-chat)
AI_MODEL=
AI_EFFORT=medium

# ─────────────────────────────────────────────────────────────
# Ledger del neobanco (saldos internos) + faucet de desarrollo
# ─────────────────────────────────────────────────────────────
LEDGER_ASSETS=USDT,USDC
# Faucet = acreditar saldo de prueba. NUNCA true en producción.
FAUCET_ENABLED=false
FAUCET_MAX=1000

# ─────────────────────────────────────────────────────────────
# Red EVM real (Sepolia testnet). RPC en orden de preferencia:
#   1) ALCHEMY_API_KEY  → https://eth-sepolia.g.alchemy.com/v2/<key>  (RECOMENDADO:
#      archive getLogs, rate limits altos, base para webhooks de depósito)
#   2) EVM_RPC_URL      → override directo de cualquier RPC
#   3) sin nada         → público https://sepolia.drpc.org (soporta getLogs)
# Crea una app gratis en https://dashboard.alchemy.com (network: Ethereum Sepolia).
# ─────────────────────────────────────────────────────────────
ALCHEMY_API_KEY=
EVM_RPC_URL=
EVM_CHAIN_ID=11155111
EVM_CHAIN_NAME=Sepolia
EVM_EXPLORER_URL=https://sepolia.etherscan.io
EVM_NATIVE_SYMBOL=ETH
# USDC oficial de Circle en Sepolia
EVM_USDC_ADDRESS=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238

# ─────────────────────────────────────────────────────────────
# Custodia: mnemónico maestro para derivar direcciones de depósito por usuario (HD).
# DEV/testnet solamente. En PRODUCCIÓN va en KMS/HSM/MPC, NUNCA en .env.
#   node -e "console.log(require('viem/accounts').generateMnemonic(require('viem/accounts').english))"
# ─────────────────────────────────────────────────────────────
CUSTODY_MNEMONIC=

# ─────────────────────────────────────────────────────────────
# KYC (verificación de identidad). Orquestación + OCR/MRZ + screening OFAC son
# PROPIOS. El proveedor cubre solo liveness/autenticidad del documento:
#   KYC_PROVIDER=manual → revisión manual del operador (sin dependencia externa)
#   KYC_PROVIDER=didit  → Didit (KYC gratis); requiere DIDIT_API_KEY
# ─────────────────────────────────────────────────────────────
KYC_PROVIDER=manual
DIDIT_API_KEY=

# ─────────────────────────────────────────────────────────────
# Indexer de depósitos on-chain (acredita USDC entrante al ledger).
# ─────────────────────────────────────────────────────────────
DEPOSIT_INDEXER_ENABLED=false
EVM_CONFIRMATIONS=3
DEPOSIT_SCAN_RANGE=2000

# ─────────────────────────────────────────────────────────────
# Autenticación (JWT en cookies httpOnly + 2FA TOTP)
# OBLIGATORIO: genera secretos reales y fuertes (mín. 32 chars):
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Nunca uses valores de ejemplo en producción.
# ─────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
BCRYPT_ROUNDS=12
TOTP_ISSUER=Zentto Web3
COOKIE_DOMAIN=
# En producción (HTTPS): COOKIE_SECURE=true y COOKIE_SAMESITE=none si front y API en dominios distintos.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# ─────────────────────────────────────────────────────────────
# Red P2P (gossip de tx/bloques + sync + resolución de forks).
# Deshabilitada por defecto: el nodo funciona standalone.
# Para una red multi-nodo, ver docker-compose.p2p.yml.
# ─────────────────────────────────────────────────────────────
P2P_ENABLED=false
P2P_PORT=6001
# Lista separada por comas de peers: ws://host:puerto,ws://host2:puerto
PEERS=
NODE_NAME=node-1
